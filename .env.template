# Copy to .env and fill in for local dev only.
# In production, all secrets come from the KMS — never from this file.
NODE_ENV=development
KMS_URL=https://your-kms.example.com/release

# ML-KEM-1024 Admin Keypair (optional - for future ML-KEM endpoints)
# Generate with: pnpm ts-node scripts/generate-admin-keypair.ts
# Note: ML-KEM encryption utilities exist in src/encryption/ but endpoints are not currently exposed
#ADMIN_MLKEM_PUBLIC_KEY=
#ADMIN_MLKEM_PRIVATE_KEY=

# Claude API Key (optional - uses mock responses if not set)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ZK Contract Configuration
ZK_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# RPC Configuration
# For local development with Anvil:
ANVIL_RPC_URL=http://127.0.0.1:8545
# For production Ethereum mainnet (comma-separated list - API will randomly pick one):
ETHEREUM_RPC_URLS=https://eth.drpc.org,https://rpc.mevblocker.io/fullprivacy,https://rpc.mevblocker.io/noreverts,https://rpc.mevblocker.io/fast,https://rpc.mevblocker.io,https://rpc.flashbots.net/fast,https://rpc.flashbots.net,https://mainnet.gateway.tenderly.co,https://ethereum-rpc.publicnode.com

# Anvil default account #0 private key - used for submitting slashing transactions
ANVIL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80