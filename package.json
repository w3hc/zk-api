{
  "name": "zk-api",
  "version": "0.1.0",
  "description": "ZK API Usage Credits",
  "author": "Julien Béranger",
  "license": "LGPL-3.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:mlkem": "ts-node scripts/test-mlkem-flow.ts",
    "test:store-access": "ts-node scripts/test-store-and-access.ts",
    "test:snarkjs": "ts-node scripts/test-snarkjs-integration.ts",
    "verify:attestation": "ts-node scripts/verify-attestation.ts",
    "setup:circuit": "ts-node scripts/setup-trusted-setup.ts",
    "test:zk": "bash scripts/test-complete-flow.sh && bash scripts/test-double-spend.sh && bash scripts/test-invalid-proofs.sh && bash scripts/test-refund-redemption.sh",
    "dance": "pnpm format && pnpm lint && pnpm test && pnpm test:e2e && pnpm build && pnpm outdated || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@phala/dstack-sdk": "^0.5.7",
    "better-sqlite3": "12.8.0",
    "circomlibjs": "^0.1.7",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ethers": "^6.16.0",
    "helmet": "^8.1.0",
    "mlkem": "^2.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "siwe": "^3.0.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^10.0.1",
    "@iden3/contracts": "^3.4.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "circomlib": "^2.0.5",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.4.0",
    "jest": "^30.0.0",
    "poseidon-solidity": "^0.0.5",
    "prettier": "^3.4.2",
    "snarkjs": "^0.7.6",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/../jest.setup.ts"
    ]
  },
  "packageManager": "pnpm@10.23.0+sha1.b4a44ab0dc2adf2e36371d11d8eb0dc78ffc976c"
}